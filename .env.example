# 应用配置
APP_NAME=AI写标书助手
APP_VERSION=3.0.0
DEBUG=true

# 数据库配置
DATABASE__SQLITE_PATH=data/bidcraft.db
DATABASE__SQLITE_ECHO=false

# Redis配置
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__DB=0
REDIS__PASSWORD=
REDIS__MAX_CONNECTIONS=10

# MinIO配置
MINIO__ENDPOINT=localhost:9000
MINIO__ACCESS_KEY=minioadmin
MINIO__SECRET_KEY=minioadmin
MINIO__SECURE=false
MINIO__BUCKET_NAME=bidcraft

# Qdrant配置
QDRANT__HOST=localhost
QDRANT__PORT=6333
QDRANT__GRPC_PORT=6334
QDRANT__PREFER_GRPC=false
QDRANT__COLLECTION_NAME=bid_documents

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
